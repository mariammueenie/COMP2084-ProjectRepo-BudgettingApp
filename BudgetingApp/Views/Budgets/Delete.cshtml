@model BudgetingApp.Models.Budget
@using System.Globalization

@{
    ViewData["Title"] = "Delete Budget";
}

<div class="page-header">
    <div>
        <h1 class="h3 m-0">Delete Budget</h1>
        <div class="text-muted small">Confirm removal</div>
    </div>
    <a class="btn btn-outline-secondary" asp-action="Index" asp-route-month="@Model.Month">Back</a>
</div>

<div class="card shadow-sm ui-card border border-danger-subtle">
    <div class="card-body">
        <div class="alert alert-danger mb-3">
            This will permanently delete the budget entry.
        </div>

        <dl class="row mb-0">
            <dt class="col-sm-3">Month</dt>
            <dd class="col-sm-9">@Model.Month.ToString("MMMM yyyy")</dd>

            <dt class="col-sm-3">Category</dt>
            <dd class="col-sm-9">@Model.Category?.Name</dd>

            <dt class="col-sm-3">Amount</dt>
            <dd class="col-sm-9">@Model.Amount.ToString("C", CultureInfo.CurrentCulture)</dd>
        </dl>

        <form asp-action="Delete" method="post" class="mt-3">
            <input type="hidden" asp-for="BudgetId" />
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-danger">Delete</button>
                <a class="btn btn-outline-secondary" asp-action="Index" asp-route-month="@Model.Month">Cancel</a>
            </div>
        </form>
    </div>
</div>