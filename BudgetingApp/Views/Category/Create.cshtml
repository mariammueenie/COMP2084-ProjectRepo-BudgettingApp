@model BudgetingApp.Models.Category

@{
    ViewData["Title"] = "Create Category";
}

<div class="page-header">
    <div>
        <h1 class="h3 m-0">Create Category</h1>
        <div class="text-muted small">Add a category to organize budgets and spending</div>
    </div>
    <a class="btn btn-outline-secondary" asp-action="Index">Back</a>
</div>

<div class="card shadow-sm ui-card">
    <div class="card-body">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="Name" class="form-label"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Create</button>
                <a class="btn btn-outline-secondary" asp-action="Index">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}